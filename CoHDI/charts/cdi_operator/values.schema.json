{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Composable Resource Operator Chart Values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": true,
      "description": "Permits umbrella charts to pass global values."
    },
    "operator": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "systemNamespace": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "controllerSA": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "replicas": {
          "type": "integer",
          "minimum": 1
        }
      },
      "required": ["name", "systemNamespace", "controllerSA", "replicas"]
    },
    "image": {
      "type": "string",
      "minLength": 1,
      "description": "Full image reference registry/repo:tag"
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"]
    },
    "webhook": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "client" : {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "caBundle": {
                  "type": "string",
                  "minLength": 1,
                  "description": "Base64-encoded CA bundle used by CDI Operator webhook or API clients."
                }
            },
            "required": ["caBundle"]
        },
        "server": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "secretName": {
              "type": "string",
              "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
            },
            "crt": { "type": "string", "minLength": 1 },
            "key": { "type": "string", "minLength": 1 }
          },
          "required": ["secretName","crt","key"]
        }
      },
      "required": ["server"]
    },
    "managerEnv": {
      "type": "object",
      "additionalProperties": { "type": "string" },
      "description": "Key-value environment variables injected into the manager container."
    }
  },
  "required": ["operator", "image", "imagePullPolicy", "webhook", "managerEnv"]
}
