{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "dynamic-device-scaler Helm values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the container or app.",
      "default": "dynamic-device-scaler",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 0,
      "default": 10,
      "description": "Number of seconds Kubernetes will wait before forcefully terminating the pod."
    },
    "image": {
      "type": "string",
      "minLength": 1,
      "description": "Full container image reference, e.g. registry/repo:tag."
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"],
      "default": "IfNotPresent",
      "description": "Kubernetes image pull policy."
    },
    "env": {
      "type": "object",
      "description": "Environment variables for the container.",
      "default": {},
      "additionalProperties": { "type": "string" },
      "properties": {
        "SCAN_INTERVAL": {
          "type": "string",
          "pattern": "^[0-9]+$",
          "description": "Interval (in seconds) between scans, e.g. '10'."
        }
      }
    }
  },
  "required": ["name", "image"]
}
