{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cdi-dra Helm values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Release/name prefix used for resources.",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "createNamespace": {
      "type": "boolean",
      "description": "Render templates/namespace.yaml when true.",
      "default": true
    },
    "namespace": {
      "type": "string",
      "description": "Target Kubernetes namespace for namespaced resources.",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "replicaCount": {
      "type": "integer",
      "minimum": 1,
      "default": 1,
      "description": "Number of replicas for the Deployment."
    },
    "image": {
      "type": "string",
      "minLength": 1,
      "description": "Full image reference, e.g. registry/repo:tag"
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"],
      "default": "IfNotPresent",
      "description": "Kubernetes image pull policy."
    },
    "env": {
      "type": "object",
      "description": "Environment variables for the container (string values).",
      "default": {},
      "additionalProperties": {
        "type": "string"
      }
    },
    "configmap": {
      "type": "object",
      "description": "ConfigMap content and related settings.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        }
      },
      "required": ["name"]
    },
    "secret": {
      "type": "object",
      "description": "Opaque Secret stringData values.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        }
      }
    }
  },
  "required": ["name", "namespace", "image"]
}
