{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "cdi-dra Helm values",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "description": "Name of the deployment or release.",
      "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
    },
    "image": {
      "type": "string",
      "description": "Full image reference, e.g. registry/repo:tag",
      "minLength": 1
    },
    "imagePullPolicy": {
      "type": "string",
      "enum": ["Always", "IfNotPresent", "Never"],
      "default": "IfNotPresent",
      "description": "Kubernetes image pull policy."
    },
    "args": {
      "type": "array",
      "description": "Container command arguments.",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "env": {
      "type": "object",
      "description": "Environment variables for the container.",
      "additionalProperties": {
        "type": "string"
      },
      "properties": {
        "USE_CAPI_BMH": {
          "type": "string",
          "enum": ["true", "false"],
          "default": "false",
          "description": "Enable or disable CAPI BareMetalHost integration."
        },
        "USE_CM": {
          "type": "string",
          "enum": ["true", "false"],
          "default": "false",
          "description": "Enable or disable Cluster Manager integration."
        },
        "SCAN_INTERVAL": {
          "type": "string",
          "pattern": "^[0-9]+s$",
          "default": "5s",
          "description": "Interval for scanning operations (e.g. '5s')."
        }
      }
    }
  },
  "required": ["name", "image"]
}
