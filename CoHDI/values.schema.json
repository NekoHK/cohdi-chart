{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "global": {
      "type": "object",
      "properties": { "namespace": { "type": "string" } }
    },
    "cdi-dra": {
      "type": "object",
      "properties": {
        "createNamespace": { "type": "boolean" },
        "namespace": { "type": "string" },
        "image": { "type": "string" },
        "replicas": { "type": "integer", "minimum": 0 },
        "labelPrefix": { "type": "string" },
        "fabricIdRange": { "type": "string" },
        "configMapName": { "type": "string" },
        "deviceInfo": { "type": "string" },
        "secretName": { "type": "string" },
        "credentials": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "realm": { "type": "string" },
            "client_id": { "type": "string" },
            "client_secret": { "type": "string" }
          }
        },
        "tls": { "type": "object", "properties": { "certificate": { "type": "string" } } },
        "hostAliases": {
          "type": "array",
          "items": { "type": "object", "properties": {
            "ip": { "type": "string" },
            "hostnames": { "type": "array", "items": { "type": "string" } }
          } }
        }
      }
    },
    "cdi-operator": {
      "type": "object",
      "properties": {
        "createNamespace": { "type": "boolean" },
        "createCredentialsNamespace": { "type": "boolean" },
        "namespace": { "type": "string" },
        "credentialsNamespace": { "type": "string" },
        "installCRDs": { "type": "boolean" },
        "credentials": {
          "type": "object",
          "properties": {
            "username": { "type": "string" },
            "password": { "type": "string" },
            "client_id": { "type": "string" },
            "client_secret": { "type": "string" }
          }
        },
        "tls": {
          "type": "object",
          "properties": {
            "crt": { "type": "string" },
            "key": { "type": "string" },
            "caCrt": { "type": "string" }
          }
        },
        "image": { "type": "string" }
      }
    },
    "dds": {
      "type": "object",
      "properties": {
        "createNamespace": { "type": "boolean" },
        "namespace": { "type": "string" },
        "image": { "type": "string" },
        "imagePullPolicy": { "type": "string" },
        "replicas": { "type": "integer", "minimum": 0 },
        "serviceAccountName": { "type": "string" },
        "scanInterval": { "type": "string" }
      }
    }
  }
}
